\tcbset{
    frame corner southeast right/.style n args={5}{
        frame code app={
            \shade[bottom color={#4},top color={#5}]
                ([xshift={#3},yshift={#1}]frame.south east)
                --++(0,{-#1-#3})
                --++({-#2},{#2})
                --++(0,{#1-#2+#3})
                --cycle;
        }
    },
    frame corner southeast bottom/.style n args={5}{
        frame code app={
            \shade[right color={#4},left color={#5}]
                ([xshift={-#1},yshift={-#3}]frame.south east)
                --++({#1+#3},0)
                --++({-#2},{#2})
                --++({-#1+#2-#3},0)
                --cycle;
        }
    },
    frame corners southeast/.style n args={5}{
        frame corner southeast right={#1}{#2}{#3}{#4}{#5},
        frame corner southeast bottom={#1}{#2}{#3}{#4}{#5},
    }
}


\newtcolorbox{enlight}[2][red]{%
  enhanced,
  breakable,
  bicolor,
  colback=white,
  colbacklower=#1!10!white,
  frame hidden,
  frame corners southeast={10mm}{2pt}{1pt}{#1!80!black}{white},
  top=5mm,
  bottom=2mm,
  middle=3.5mm,
  overlaplower=1.5mm,
  underlay={
      \node[anchor=north west,yshift=-1mm,xshift=1mm]
      at (frame.north west){#2};
  }
}

% General Styled Box
\newtcolorbox{mybox}[2][]{%
  enhanced,
  breakable,
  before skip=2mm,
  after skip=2mm,
  colback=black!5,
  colframe=black!50,
  boxrule=0.2mm,
  fonttitle=\bfseries,
  title={#2},
  #1
}

% Sticky note
% In agrument you can give the title of the note
\newtcolorbox{stkynote}[2][red]{%
    enhanced,
    before skip=2mm,after skip=2mm, 
    width=\textwidth, % width of the sticky note
    boxrule=0.2mm,
    colbacktitle = #1,
    colback=#1!20, colframe=black!60, % Colors
    attach boxed title to top left={xshift=0cm,yshift*=0mm-\tcboxedtitleheight},
    varwidth boxed title*=-3cm,
    % The titlebox:
    boxed title style={frame code={%
        \path[left color=tcbcolback!70!black,right color=tcbcolback!70!black,
        middle color=tcbcolback!80!black]
        ([xshift=-0mm]frame.north west) -- ([xshift=0mm]frame.north east)
        [rounded corners=1.5mm]-- ([xshift=0mm,yshift=0mm]frame.north east)
        -- (frame.south east) -- (frame.south west)
        -- ([xshift=0mm,yshift=0mm]frame.north west)
        [sharp corners]-- cycle;
        },interior engine=empty,
    },
    sharp corners,rounded corners=southeast,arc is angular,arc=3mm,
    % The "folded paper" in the bottom right corner:
    underlay={%
        \path[fill=#1!40!black] ([yshift=3mm]interior.south east)--++(-0.4,-0.1)--++(0.1,-0.2);
        \path[draw=#1,shorten <=-0.05mm,shorten >=-0.05mm,color=#1] ([yshift=3mm]interior.south east)--++(-0.4,-0.1)--++(0.1,-0.2);
        },
    drop fuzzy shadow, % Shadow
    fonttitle=\bfseries, 
    title={#2}
}

